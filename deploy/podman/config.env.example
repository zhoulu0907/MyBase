# ===========================================
# OneBase V3 FE 部署配置
# 部署时复制此文件为 config.env 并修改
# ===========================================

# ==================== 核心配置 ====================

# 主题：default | tiangong | lingji
THEME=default

# 后端 API 地址
BACKEND_URL=http://your-backend-server

# 前端访问地址（用于生成各服务间的跳转链接）
FRONTEND_BASE_URL=http://your-server

# ==================== 扩展配置（可选） ====================

# 数据集服务地址（默认使用 BACKEND_URL）
# DATASET_URL=http://your-dataset-server

# Dashboard 地址（默认使用 FRONTEND_BASE_URL）
# DASHBOARD_URL=http://your-dashboard-server

# AI 服务基础地址（自动拼接 /aigenapp/ 和 /aicopilot/）
# AI_BASE_URL=https://ai-server

# SSO 配置
# SSO_HOME=https://your-sso-server/home
# SSO_SOURCE_ID=your_sso_app_id