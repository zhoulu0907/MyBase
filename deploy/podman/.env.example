# ===========================================
# OneBase V3 FE 部署配置
# ===========================================

# ==================== 核心配置 ====================

# 部署模式：port（端口模式）| path（路径模式）
DEPLOY_MODE=path

# 主题：default | tiangong | lingji
THEME=default

# 后端 API 地址
BACKEND_URL=http://your-backend-server

# 前端访问地址（用于生成各服务间的跳转链接）
# 端口模式示例：http://your-server
# 路径模式示例：http://your-server/onebase
FRONTEND_BASE_URL=http://your-server

# ==================== 端口配置 ====================

# 网关端口（路径模式默认使用 80）
NGINX_PORT=80

# 各服务端口（端口模式使用）
# App Builder 端口
APP_BUILDER_PORT=4399
# Admin Console 端口
ADMIN_CONSOLE_PORT=4402
# Runtime 端口
RUNTIME_PORT=9527
# Mobile Runtime 端口
MOBILE_RUNTIME_PORT=9528
# Mobile Editor 端口
MOBILE_EDITOR_PORT=4401

# ==================== 路径配置（路径模式） ====================
# 仅在 DEPLOY_MODE=path 时生效

# App Builder 路径
APP_BUILDER_PATH=/appbuilder
# Admin Console 路径
ADMIN_CONSOLE_PATH=/console
# Runtime 路径
RUNTIME_PATH=/runtime
# Mobile Runtime 路径
MOBILE_RUNTIME_PATH=/mobile-runtime
# Mobile Editor 路径
MOBILE_EDITOR_PATH=/mobile-editor

# ==================== 扩展配置（可选） ====================

# 数据集服务地址（默认使用 BACKEND_URL）
# DATASET_URL=http://your-dataset-server

# Dashboard 地址（默认使用 FRONTEND_BASE_URL）
# DASHBOARD_URL=http://your-dashboard-server

# AI 服务基础地址（自动拼接 /aigenapp/ 和 /aicopilot/）
# AI_BASE_URL=https://ai-server

# Flink 服务地址（路径模式网关代理）
# FLINK_URL=http://your-flink-server:8081

# SSO 配置
# SSO_HOME=https://your-sso-server/home
# SSO_SOURCE_ID=your_sso_app_id

# ==================== 构建配置 ====================

# 镜像仓库地址
REGISTRY=

# 镜像前缀
IMAGE_PREFIX=onebase-v3-fe

# 镜像版本
VERSION=v3.0.0

# 构建平台（根据服务器架构选择）
# x86_64 服务器：linux/amd64
# arm64 服务器：linux/arm64
PLATFORM=linux/arm64