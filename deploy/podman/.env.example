# OneBase 后端构建环境变量
# ================================
# 部署时请复制此文件为 .env 并根据实际情况修改
#
# cp .env.example .env

# ====================
# 架构配置
# ====================
# 自动检测: x86_64/amd64 -> linux/amd64, arm64/aarch64 -> linux/arm64
# 手动指定:
# PLATFORM=linux/amd64   # x86_64 服务器
# PLATFORM=linux/arm64   # arm64 服务器

# ====================
# 版本配置
# ====================
VERSION=v1.0.0