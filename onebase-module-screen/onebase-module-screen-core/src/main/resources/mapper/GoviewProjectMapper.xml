<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cmsr.onebase.module.screen.build.v2.mapper.GoviewProjectMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.cmsr.onebase.module.screen.build.v2.model.GoviewProject">
        <id column="id" property="id" />
        <result column="project_name" property="projectName" />
        <result column="state" property="state" />
        <result column="create_time" property="createTime" />
        <result column="create_user_id" property="createUserId" />
        <result column="is_delete" property="isDelete" />
        <result column="index_image" property="indexImage" />
        <result column="remarks" property="remarks" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, project_name, state, create_time, create_user_id, is_delete, index_image, remarks
    </sql>
    
    <!-- 针对 MyBatis-Plus 的 selectList 方法提供显式映射 -->
    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM t_goview_project
        <where>
            is_delete = 0
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
    </select>

</mapper>