@host = localhost
@port = 48081
@prefix = /runtime
@base = http://{{host}}:{{port}}{{prefix}}

@entityCode = SAMPLE_ENTITY_CODE
@menuId = 113431890281824256
@traceId = {{$uuid}}
@sortFieldName = id

### 语义创建（字段名与连接器名作为顶层键）
POST {{base}}/metadata/{{entityCode}}/create?menuId={{menuId}}
Content-Type: application/json
X-Trace-Id: {{traceId}}

{
  "order_id": "ORD-0001",
  "order_source": "web",
  "order_platform": "amazon",
  "order_items": [
    { "sku": "SKU-1", "qty": 2 },
    { "sku": "SKU-2", "qty": 1 }
  ]
}

### 语义更新（包含主键 id）
POST {{base}}/metadata/{{entityCode}}/update?menuId={{menuId}}
Content-Type: application/json
X-Trace-Id: {{traceId}}

{
  "id": 1,
  "order_source": "phone"
}

### 语义删除（data 中包含 id）
POST {{base}}/metadata/{{entityCode}}/remove?menuId={{menuId}}
Content-Type: application/json
X-Trace-Id: {{traceId}}

{
  "data": { "id": 1 }
}

### 语义详情（支持包含子表/关系）
POST {{base}}/metadata/{{entityCode}}/detail?menuId={{menuId}}
Content-Type: application/json
X-Trace-Id: {{traceId}}

{
  "data": { "id": 1 },
  "containSubTable": true,
  "containRelation": true
}

### 语义分页（分页/排序/过滤在 body 中）
POST {{base}}/metadata/{{entityCode}}/page?menuId={{menuId}}
Content-Type: application/json
X-Trace-Id: {{traceId}}

{
  "data": {},
  "pageNo": 1,
  "pageSize": 10,
  "sortField": "{{sortFieldName}}",
  "sortDirection": "desc",
  "filters": {
    "order_source": "web"
  }
}
