    "/metadata/{tableName}/update": {
      "post": {
        "tags": ["动态数据(语义)"],
        "summary": "更新",
        "parameters": [
          { "$ref": "#/components/parameters/TableName" },
          { "$ref": "#/components/parameters/MenuId" },
          { "$ref": "#/components/parameters/TraceIdHeader" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SemanticMergeBodyVO" },
              "examples": {
                "update_full": {
                  "value": {
                    "id": 1001,
                    "name": "示例名称-更新",
                    "status": 2,
                    "description": "完整更新示例",
                    "updateTime": "2025-12-02T12:00:00Z",
                    "connector_user": { "id": 2002, "name": "李四" },
                    "connector_orders": [
                      { "id": 3001, "amount": 189.99, "currency": "CNY" },
                      { "id": 3003, "amount": 99.00, "currency": "CNY" }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新后的动态数据响应",
            "headers": { "X-Trace-Id": { "$ref": "#/components/headers/XTraceId" } },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CommonResultObject" },
                "examples": {
                  "success_full": {
                    "value": {
                      "code": 0,
                      "msg": "",
                      "data": {
                        "id": 1001,
                        "name": "示例名称-更新",
                        "status": 2,
                        "description": "完整更新示例",
                        "updateTime": "2025-12-02T12:00:00Z",
                        "connector_user": { "id": 2002, "name": "李四" },
                        "connector_orders": [
                          { "id": 3001, "amount": 189.99, "currency": "CNY" },
                          { "id": 3003, "amount": 99.00, "currency": "CNY" }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/metadata/{tableName}/delete": {
      "post": {
        "tags": ["动态数据(语义)"],
        "summary": "删除",
        "parameters": [
          { "$ref": "#/components/parameters/TableName" },
          { "$ref": "#/components/parameters/MenuId" },
          { "$ref": "#/components/parameters/TraceIdHeader" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SemanticTargetBodyVO" },
              "examples": {
                "delete_full": {
                  "value": {
                    "id": 1001,
                    "containSubTable": false,
                    "containRelation": false,
                    "methodCode": "SOFT_DELETE"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "删除是否成功",
            "headers": { "X-Trace-Id": { "$ref": "#/components/headers/XTraceId" } },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CommonResultBoolean" },
                "examples": {
                  "success_full": {
                    "value": { "code": 0, "msg": "", "data": true }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/metadata/{tableName}/detail": {
      "post": {
        "tags": ["动态数据(语义)"],
        "summary": "详情",
        "parameters": [
          { "$ref": "#/components/parameters/TableName" },
          { "$ref": "#/components/parameters/MenuId" },
          { "$ref": "#/components/parameters/TraceIdHeader" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SemanticTargetBodyVO" },
              "examples": {
                "detail_full": {
                  "value": {
                    "id": 1001,
                    "containSubTable": true,
                    "containRelation": true,
                    "methodCode": "READ_DETAIL"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "详情动态数据响应",
            "headers": { "X-Trace-Id": { "$ref": "#/components/headers/XTraceId" } },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CommonResultObject" },
                "examples": {
                  "success_full": {
                    "value": {
                      "code": 0,
                      "msg": "",
                      "data": {
                        "id": 1001,
                        "name": "示例名称",
                        "status": 1,
                        "description": "详情完整示例",
                        "createTime": "2025-12-02T10:00:00Z",
                        "updateTime": "2025-12-02T12:00:00Z",
                        "connector_user": { "id": 2001, "name": "张三" },
                        "connector_orders": [
                          { "id": 3001, "amount": 199.99, "currency": "CNY" },
                          { "id": 3002, "amount": 299.00, "currency": "CNY" }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/metadata/{tableName}/page": {
      "post": {
        "tags": ["动态数据(语义)"],
        "summary": "分页",
        "parameters": [
          { "$ref": "#/components/parameters/TableName" },
          { "$ref": "#/components/parameters/MenuId" },
          { "$ref": "#/components/parameters/TraceIdHeader" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SemanticPageBodyVO" },
              "examples": {
                "page_full": {
                  "value": {
                    "data": { "status": 1, "keyword": "示例" },
                    "pageNo": 1,
                    "pageSize": 20,
                    "sortField": "updateTime",
                    "sortDirection": "DESC",
                    "filters": { "status": 1, "dateRange": ["2025-12-01", "2025-12-02"] }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "分页结果",
            "headers": { "X-Trace-Id": { "$ref": "#/components/headers/XTraceId" } },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CommonResultPageResultObject" },
                "examples": {
                  "success_full": {
                    "value": {
                      "code": 0,
                      "msg": "",
                      "data": {
                        "list": [
                          {
                            "id": 1001,
                            "name": "示例名称A",
                            "status": 1,
                            "description": "分页记录A",
                            "updateTime": "2025-12-02T12:00:00Z",
                            "connector_user": { "id": 2001, "name": "张三" },
                            "connector_orders": [ { "id": 3001, "amount": 189.99, "currency": "CNY" } ]
                          },
                          {
                            "id": 1002,
                            "name": "示例名称B",
                            "status": 2,
                            "description": "分页记录B",
                            "updateTime": "2025-12-02T11:00:00Z",
                            "connector_user": { "id": 2002, "name": "李四" },
                            "connector_orders": [ { "id": 3002, "amount": 299.00, "currency": "CNY" } ]
                          }
                        ],
                        "total": 2
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "TableName": {
        "name": "tableName",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "表名，用于解析实体ID",
        "example": "user"
      },
      "MenuId": {
        "name": "menuId",
        "in": "query",
        "required": true,
        "schema": { "type": "integer", "format": "int64" },
        "description": "菜单ID（用于权限与上下文）",
        "example": 1
      },
      "TraceIdHeader": {
        "name": "X-Trace-Id",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "链路追踪ID（可传入；若缺失由服务生成并在响应头返回）",
        "example": "b3d7c3d8-1234-4f6a-9abc-ef0123456789"
      }
    },
    "headers": {
      "XTraceId": { "description": "链路追踪ID", "schema": { "type": "string" } }
    },
    "schemas": {
      "CommonResultObject": {
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "msg": { "type": "string" },
          "data": { "type": "object", "additionalProperties": true }
        },
        "required": ["code", "data", "msg"]
      },
      "CommonResultBoolean": {
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "msg": { "type": "string" },
          "data": { "type": "boolean" }
        },
        "required": ["code", "data", "msg"]
      },
      "CommonResultPageResultObject": {
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "msg": { "type": "string" },
          "data": { "$ref": "#/components/schemas/PageResultObject" }
        },
        "required": ["code", "data", "msg"]
      },
      "PageResultObject": {
        "type": "object",
        "properties": {
          "list": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "total": { "type": "integer", "format": "int64" }
        },
        "required": ["list", "total"]
      },
      "SemanticMergeBodyVO": {
        "type": "object",
        "additionalProperties": true,
        "description": "顶层键为业务字段或连接器名称，用于创建/更新"
      },
      "SemanticTargetBodyVO": {
        "type": "object",
        "properties": {
          "id": {
            "oneOf": [ { "type": "integer", "format": "int64" }, { "type": "string" } ],
            "description": "目标数据主键id"
          },
          "containSubTable": { "type": "boolean", "description": "是否包含子表(详情用)" },
          "containRelation": { "type": "boolean", "description": "是否包含关系(详情用)" },
          "methodCode": { "type": "string", "description": "方法编码" }
        },
        "required": ["id"],
        "description": "删除/详情场景请求体"
      },
      "SemanticPageBodyVO": {
        "type": "object",
        "properties": {
          "data": { "type": "object", "additionalProperties": true, "description": "业务数据包装" },
          "pageNo": { "type": "integer" },
          "pageSize": { "type": "integer" },
          "sortField": { "type": "string" },
          "sortDirection": { "type": "string", "enum": ["ASC", "DESC"] },
          "filters": { "type": "object", "additionalProperties": true }
        },
        "description": "分页参数、排序与过滤"
      }
    }
  }
}
