<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.cmsr.onebase</groupId>
        <artifactId>onebase-plugin-demo</artifactId>
        <version>${revision}</version>
    </parent>

    <artifactId>plugin-demo-test</artifactId>
    <packaging>jar</packaging>

    <name>${project.artifactId}</name>
    <description>OneBase插件开发示例 - Test模块</description>

    <dependencies>
        <!-- OneBase 插件 SDK -->
        <dependency>
            <groupId>com.cmsr.onebase</groupId>
            <artifactId>onebase-plugin-sdk</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Spring Web - 用于 @RestController 等注解 -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
            <scope>provided</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- OneBase插件Maven插件 - 提供自动生成和打包能力 -->
            <plugin>
                <groupId>com.cmsr.onebase</groupId>
                <artifactId>onebase-plugin-maven-plugin</artifactId>
                <executions>
                    <!-- 1. 自动生成插件主类 GeneratedPlugin - 包名通过 generatedPackage 参数指定 -->
                    <execution>
                        <id>generate-plugin-class</id>
                        <goals>
                            <goal>generate-plugin-class</goal>
                        </goals>
                        <configuration>
                            <generatedPackage>com.cmsr.onebase.plugin.demo.test</generatedPackage>
                        </configuration>
                    </execution>

                    <!-- 2. 自动生成插件配置文件 plugin.properties -->
                    <execution>
                        <id>generate-properties</id>
                        <goals>
                            <goal>generate-properties</goal>
                        </goals>
                        <configuration>
                            <!-- 插件唯一标识 -->
                            <pluginId>test-plugin</pluginId>
                            <!-- 插件版本，通常引用项目版本 -->
                            <pluginVersion>${project.version}</pluginVersion>
                            <!-- 插件描述 -->
                            <pluginDescription>OneBase演示插件 - Test模块，展示HttpHandler等扩展点的使用</pluginDescription>
                            <!-- 插件提供者 -->
                            <pluginProvider>OneBase Team</pluginProvider>
                        </configuration>
                    </execution>

                    <!-- 3. 自动扫描扩展点，生成META-INF/extensions.idx索引文件 (无需额外配置) -->
                    <execution>
                        <id>scan-extensions</id>
                        <goals>
                            <goal>scan-extensions</goal>
                        </goals>
                    </execution>

                    <!-- 4. 自动打包成 ZIP (无需额外配置) -->
                    <execution>
                        <id>package-plugin</id>
                        <goals>
                            <goal>package-plugin</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!-- Maven Compiler插件 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
            </plugin>

            <!-- Maven JAR插件 - 禁止生成插件相关的MANIFEST属性 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <archive>
                        <!-- 不添加任何PF4J插件属性到MANIFEST.MF -->
                        <addMavenDescriptor>false</addMavenDescriptor>
                    </archive>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>