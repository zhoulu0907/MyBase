<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.cmsr.onebase</groupId>
        <artifactId>onebase-plugin</artifactId>
        <version>${revision}</version>
    </parent>

    <artifactId>onebase-plugin-demo</artifactId>
    <packaging>pom</packaging>

    <name>${project.artifactId}</name>
    <description>OneBase低代码平台插件开发示例</description>

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <!-- ❗ 必须启用，否则 Spring MVC 无法通过反射获取方法参数名 -->
        <maven.compiler.parameters>true</maven.compiler.parameters>
        <!-- 版本管理 -->
        <onebase-dependencies.version>1.0.0-SNAPSHOT</onebase-dependencies.version>
        <onebase-plugin-maven-plugin.version>1.0.0-SNAPSHOT</onebase-plugin-maven-plugin.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- ❗必须导入 OneBase BOM，统一版本管理，否则可能引发版本冲突 -->
            <dependency>
                <groupId>com.cmsr.onebase</groupId>
                <artifactId>onebase-dependencies</artifactId>
                <version>${onebase-dependencies.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <modules>
        <!-- 子模块列表 -->
        <module>plugin-demo-hello</module>
        <module>plugin-demo-test</module>
    </modules>

    <build>
        <pluginManagement>
            <plugins>
                <!-- OneBase插件Maven插件 - 提供自动生成和打包能力 -->
                <plugin>
                    <groupId>com.cmsr.onebase</groupId>
                    <artifactId>onebase-plugin-maven-plugin</artifactId>
                    <version>${onebase-plugin-maven-plugin.version}</version>
                </plugin>

                <!-- Maven JAR插件 - 禁止生成插件相关的MANIFEST属性 -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-jar-plugin</artifactId>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>
</project>
