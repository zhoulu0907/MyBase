# =========================================
# OneBase 插件系统配置示例
# =========================================

# 是否启用插件系统
onebase.plugin.enabled=true

# 插件目录路径（相对路径或绝对路径）
onebase.plugin.plugins-dir=plugins

# 运行模式，可选：dev、staging、prod；默认prod
onebase.plugin.mode=prod

# 是否自动加载插件（应用启动时加载plugins目录下的所有插件）；默认true
onebase.plugin.auto-load=true

# 是否自动启动插件（插件加载后自动启动）；默认true
onebase.plugin.auto-start=true
