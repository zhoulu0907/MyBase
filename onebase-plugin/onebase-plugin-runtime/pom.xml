<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <groupId>com.cmsr.onebase</groupId>
        <artifactId>onebase-plugin</artifactId>
        <version>${revision}</version>
    </parent>
    <modelVersion>4.0.0</modelVersion>

    <artifactId>onebase-plugin-runtime</artifactId>
    <packaging>jar</packaging>

    <name>${project.artifactId}</name>
    <description>插件运行态模块，提供插件管理的运行态服务</description>

    <dependencies>
        <!-- 插件公共模块 -->
        <dependency>
            <groupId>com.cmsr.onebase</groupId>
            <artifactId>onebase-plugin-common</artifactId>
            <version>${revision}</version>
        </dependency>

        <!-- 依赖插件核心模块 -->
        <dependency>
            <groupId>com.cmsr.onebase</groupId>
            <artifactId>onebase-plugin-core</artifactId>
            <version>${revision}</version>
        </dependency>

        <!-- 插件SDK，定义扩展点接口 -->
        <dependency>
            <groupId>com.cmsr.onebase</groupId>
            <artifactId>onebase-plugin-sdk</artifactId>
            <version>${revision}</version>
        </dependency>

        <!-- 插件运行时 starter -->
        <dependency>
            <groupId>com.cmsr.onebase</groupId>
            <artifactId>onebase-spring-boot-starter-plugin</artifactId>
        </dependency>

        <!-- Web 相关 -->
        <dependency>
            <groupId>com.cmsr.onebase</groupId>
            <artifactId>onebase-security-runtime</artifactId>
            <version>${revision}</version>
        </dependency>

        <!-- 文件服务API -->
        <dependency>
            <groupId>com.cmsr.onebase</groupId>
            <artifactId>onebase-module-infra-api</artifactId>
            <version>${revision}</version>
        </dependency>

        <dependency>
            <groupId>com.cmsr.onebase</groupId>
            <artifactId>onebase-spring-boot-starter-biz-tenant</artifactId>
        </dependency>

        <!-- Redis -->
        <dependency>
            <groupId>com.cmsr.onebase</groupId>
            <artifactId>onebase-spring-boot-starter-redis</artifactId>
        </dependency>

        <!-- SLF4J日志 -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Test 测试相关 -->
        <dependency>
            <groupId>com.cmsr.onebase</groupId>
            <artifactId>onebase-spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <!-- 设置构建的 jar 包名 -->
        <finalName>${project.artifactId}</finalName>
        <plugins>
            <!-- 打包 -->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <version>${spring.boot.version}</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
                <!-- 注意，单体模式打包需要这个配置，Cloud模式不需要。 -->
                <configuration>
                    <skip>true</skip>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
