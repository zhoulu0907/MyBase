## 默认环境变量配置（直接使用local环境配置）
# 使用全局环境配置文件 http-client.env.json
# 请在IntelliJ IDEA中选择对应环境: local/dev/test/gateway
# 登录成功后会自动更新token到环境变量中

### 超管登录 => 成功
POST {{baseUrl}}/system/auth/tenant-login
Content-Type: application/json
X-Tenant-Id: 184717008866115584

{"username":"zhuchunhui","password":"a1495fcfc6eeed115ff8e73aad07e7c2c223b207f8dd6f240ae80dc61ccc0180af24af5e99e81988699488cad581bb1dd57e8c1f45966e321d87fe3098d55641d8ec87f30b065ff72b1d1c5c574bb93fa7deebda4b56e015af2c94e1906dda853bcd767464ea296f5ecd89b66aa8f6","captchaVerification":"GSjRjRGx9ntfsGkLLaPtInfuB+hcDREbT9fKKNkSGl923GpAJfCQRIJgbXbuJteCk94rvCI93Bczj1kmBhGoB0etQe4MoEwSS0PzfzJZg1Q=","deviceId":"60c78cdd38ca3836b7176be580f57e4c"}
> {%
    // 登录成功后自动更新token到环境变量
    if (response.status === 200) {
        const responseData = response.body;
        if (responseData.code === 0 && responseData.data && responseData.data.accessToken) {
            client.global.set("token", responseData.data.accessToken);
            console.log("Token已更新: " + responseData.data.accessToken);
        }
    }
%}

