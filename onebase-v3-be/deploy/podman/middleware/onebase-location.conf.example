# OneBase 后端 API Location 配置
# ================================
# 放在 server 块中引用: include /path/to/onebase-location.conf;
#
# 部署时请复制此文件
# cp onebase-location.conf.example onebase-location.conf
#
# 访问地址:
#   编辑态 API: /build-api/admin-api/...
#   运行态 API: /runtime-api/runtime-api/...
#   Flink API:  /flink-api/...
#
# 示例:
#   登录接口: /build-api/admin-api/system/auth/login
#   页面列表: /build-api/admin-api/app/page/list

# ====================
# 编辑态服务 API
# ====================
location /build-api/ {
    rewrite ^/build-api/(.*) /$1 break;
    proxy_pass http://onebase-build;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # 超时配置
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;

    # 上传文件大小限制
    client_max_body_size 100m;
}

# 编辑态 WebSocket
location /build-api/ws/ {
    rewrite ^/build-api/(.*) /$1 break;
    proxy_pass http://onebase-build;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    # WebSocket 超时
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
}

# ====================
# 运行态服务 API
# ====================
location /runtime-api/ {
    rewrite ^/runtime-api/(.*) /$1 break;
    proxy_pass http://onebase-runtime;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # 超时配置
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;

    # 上传文件大小限制
    client_max_body_size 100m;
}

# 运行态 WebSocket
location /runtime-api/ws/ {
    rewrite ^/runtime-api/(.*) /$1 break;
    proxy_pass http://onebase-runtime;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    # WebSocket 超时
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
}

# ====================
# Flink 服务 API
# ====================
location /flink-api/ {
    rewrite ^/flink-api/(.*) /$1 break;
    proxy_pass http://onebase-flink;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # 超时配置
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
}