## 默认环境变量配置（直接使用local环境配置）
# 使用全局环境配置文件 http-client.env.json
# 请在IntelliJ IDEA中选择对应环境: local/dev/test/gateway
# 登录成功后会自动更新token到环境变量中


### 请求 /login 接口 => 成功
POST {{baseUrl}}/system/auth/corp-login
Content-Type: application/json
X-Tenant-Id: 158088726951460864
tag: {{tag}}

{
  "mobile": "15890635400",
  "password": "78090bd0ca3653088c6c82966333b9d095fd42e2e917897a2d0adb31382c468401cb651c37d8f73c12f0161c0d02d321bf9dd94b01e56e1b3e57ed3c9db7175416219eca5e70d8af70cfe3b6653da859425ecb5338bfffc64a636a12bd26a9978eea0e7909526b44f8d490b13cff",
  "deviceId":666
}

> {%
    // 登录成功后自动更新token到环境变量
    if (response.status === 200) {
        const responseData = response.body;
        if (responseData.code === 0 && responseData.data && responseData.data.accessToken) {
            client.global.set("token", responseData.data.accessToken);
            console.log("Token已更新: " + responseData.data.accessToken);
        }
    }
%}


