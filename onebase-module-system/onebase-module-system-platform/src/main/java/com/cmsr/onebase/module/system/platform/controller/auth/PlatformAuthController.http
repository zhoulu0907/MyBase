## 默认环境变量配置（直接使用local环境配置）
# 使用全局环境配置文件 http-client.env.json
# 请在IntelliJ IDEA中选择对应环境: local/dev/test/gateway
# 登录成功后会自动更新token到环境变量中


### 请求 /login 密文登录 => 成功
POST {{baseUrl}}/system/auth/login
Content-Type: application/json
tenant-id: {{adminTenantId}}
tag: {{tag}}

{"username":"zhuchunhui","password":"daf9cf8fccba5c3a483246f8107ea3b08c7fa9fe5fb036b337289c537cbe0e94f3fc22068c94a61a17bf946886ed63ca811e0126856877c3ccfeedd966f65a08c2739eaae0ccc9652c487c45d65ebaebfca56f2a7ee06aeb8fcdbd2ec339e2bd3b435916ba18820fb712132ef9b0ba","captchaVerification":"kGLz/xBFDXfYREKszNF0TjVxoV3UnWpBoO12OlILrnUCSm/KoBAl/mioI6OUnX7GsZJbOIUXgaDyyfxmSzFDuQbagUzoxEp52SZrXPBfvE4=","deviceId":"60c78cdd38ca3836b7176be580f57e4c"}

> {%
    // 登录成功后自动更新token到环境变量
    if (response.status === 200) {
        const responseData = response.body;
        if (responseData.code === 0 && responseData.data && responseData.data.accessToken) {
            client.global.set("token", responseData.data.accessToken);
            console.log("Token已更新: " + responseData.data.accessToken);
        }
    }
%}


### 请求 /list-menus 接口 => 成功
GET {{baseUrl}}/system/list-menus
Authorization: Bearer {{token}}
tenant-id: {{adminTenantId}}


