### 请求 /login 接口 => 成功
POST {{baseUrl}}/system/auth/corp-login
Content-Type: application/json
tenant-id: {{adminTenantId}}
tag: {{tag}}

{
  "mobile": "15890615600",
  "password": "1183fec50c4143973fb0388eaba42230582043441995f04df793c038ac401b390fade26e103db0916e3f64df24c26128c82b220fe2d13038ab6f57ac3f9da3c154f10644ddd5f48b5044c691e631a17c9ed48ad4fd3b508ce0a41ca1a57bb5fb840defc3515ea4b90588269f48df",
  "deviceId":666
}

> {%
    // 登录成功后自动更新token到环境变量
    if (response.status === 200) {
        const responseData = response.body;
        if (responseData.code === 0 && responseData.data && responseData.data.accessToken) {
            client.global.set("token", responseData.data.accessToken);
            console.log("Token已更新: " + responseData.data.accessToken);
        }
    }
%}


### 创建企业 /admin-api/system/corp/get?id=131231231237783552
