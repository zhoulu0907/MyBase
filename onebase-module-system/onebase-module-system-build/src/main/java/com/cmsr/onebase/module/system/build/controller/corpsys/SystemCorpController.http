
### 企业创建（正常参数示例，可成功）
POST {{baseUrl}}/system/corp/create
Content-Type: application/json
Authorization: Bearer {{token}}
tenant-id: {{adminTenantId}}

{
  "corpReqVO": {
    "corpLogo": "https://static.example.com/logo/corp-test-001.png",
    "corpName": "测试企业1",
    "industryType": 1,
    "status": 0,
    "address": "北京市海淀区中关村大街1号创新大厦8层",
    "userLimit": 100
  },
  "corpAdminReqVO": {
    "username": "corp_admin1",
    "nickname": "企业管理员",
    "email": "corp_admin1@test.com",
    "mobile": "13800001111"
  }
}

