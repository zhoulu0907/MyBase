### 请求 /login 接口 => 成功
POST {{baseUrl}}/system/auth/corp-login
Content-Type: application/json
tenant-id: {{adminTenantId}}
tag: {{tag}}

{
  "mobile": "13800001111",
  "password": "<$KKy2XfYV1}frV",
  "deviceId":666
}

> {%
    // 登录成功后自动更新token到环境变量
    if (response.status === 200) {
        const responseData = response.body;
        if (responseData.code === 0 && responseData.data && responseData.data.accessToken) {
            client.global.set("token", responseData.data.accessToken);
            console.log("Token已更新: " + responseData.data.accessToken);
        }
    }
%}


### 创建企业 /admin-api/system/corp/get?id=131231231237783552
GET {{baseUrl}}/system/corp/get?id=131231231237783552
Content-Type: application/json
Authorization: Bearer {{token}}
#tenant-id: {{adminTenantId}}

### 创建企业 /admin-api/system/corp/update

POST {{baseUrl}}/system/corp/update
Content-Type: application/json
Authorization: Bearer {{token}}
tenant-id: {{adminTenantId}}
{
    "id": 115175715731800064,
