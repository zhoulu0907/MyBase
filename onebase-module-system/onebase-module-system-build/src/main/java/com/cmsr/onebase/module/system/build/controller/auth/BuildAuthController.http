## 默认环境变量配置（直接使用local环境配置）
# 使用全局环境配置文件 http-client.env.json
# 请在IntelliJ IDEA中选择对应环境: local/dev/test/gateway
# 登录成功后会自动更新token到环境变量中

### 超管登录 => 成功
POST {{baseUrl}}/system/auth/tenant-login
Content-Type: application/json
X-Tenant-Id: 174391581036773376

{"username":"gaoguoqing",
  "password":"2f09c45d45fc7086f83e9757711fe6207915416f656d4494b5f29d2ba7268ba86d9e0001b712781a5feba3ed691e6276893f7ece3e890a37972f29de0a0775743b939a02977aea43240f730054c1f1c8aa79622071a0417f58f3590fef952255fc031ed882487818f2ae3fab86ef68",
  "captchaVerification":"n89lvlHjSOsQQ5kGXjNNtdnkfPnK2Y3YbPwvAEXoVyL0TqzrDumdg8MONVs+z5VaSPf4ni6QKFhhx0GcaXBF4pWVx9hsSsBZ8mysqU8u45E=",
 "deviceId":666}

> {%
    // 登录成功后自动更新token到环境变量
    if (response.status === 200) {
        const responseData = response.body;
        if (responseData.code === 0 && responseData.data && responseData.data.accessToken) {
            client.global.set("token", responseData.data.accessToken);
            console.log("Token已更新: " + responseData.data.accessToken);
        }
    }
%}

### 请求 /get-permission-info 接口 => 成功
GET {{baseUrl}}/system/auth/get-permission-info
Authorization: Bearer {{token}}
X-Tenant-Id: {{adminTenantId}}
timestamp:1765293651000
nonce:1765293314000
sign:888

### 请求 /get-permission-info 接口+code => 成功
GET {{baseUrl}}/system/auth/get-permission-info?code=tenant
Authorization: Bearer {{token}}
X-Tenant-Id: {{adminTenantId}}


